{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "healthProfile": {
          "type": "object",
          "properties": {
            "age": { "type": "number" },
            "gender": { "type": "string" },
            "savedTopics": { "type": "array", "items": { "type": "string" } }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Booking": {
      "title": "Consultation Booking",
      "description": "Records of 1-on-1 health consultations.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "tier": { "type": "string", "enum": ["Basic", "Advanced", "Premium"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "whatsappNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "time", "tier", "status"]
    },
    "Product": {
      "title": "Digital Product",
      "description": "eBooks and health guides available for purchase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["ebook", "program"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "price", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user records"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Consultation records"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Catalogue of digital products"
    }
  }
}
